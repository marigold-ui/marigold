{
  "extends": [
    "config:recommended",
    ":semanticCommitTypeAll(chore)",
    ":rebaseStalePrs"
  ],
  "schedule": ["before 4am on Monday"],
  "timezone": "Europe/Berlin",

  "ignoreScripts": true,
  "branchConcurrentLimit": 5,

  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Broad groups first (last matching groupName wins in Renovate)",
      "groupName": "react",
      "matchPackageNames": ["/^react$/", "/^react-dom$/"]
    },
    {
      "groupName": "typescript",
      "matchPackageNames": ["/^typescript$/", "/@types/", "type-fest"]
    },
    {
      "groupName": "eslint",
      "matchPackageNames": ["/eslint/"]
    },
    {
      "groupName": "tailwind",
      "matchPackageNames": [
        "/tailwindcss/",
        "tailwind-merge",
        "/postcss/",
        "autoprefixer"
      ]
    },
    {
      "groupName": "vite",
      "matchPackageNames": ["/^vite$/", "/@vitejs/", "/^vite-/"]
    },
    {
      "groupName": "mdx",
      "matchPackageNames": [
        "/rehype/",
        "/remark/",
        "/@mdx-js/",
        "/mdast/",
        "/vfile/",
        "/unist/",
        "unified"
      ]
    },
    {
      "description": "Specific overrides below (win over broader groups above)",
      "groupName": "react-aria",
      "matchPackageNames": [
        "/@react-aria/",
        "/@react-stately/",
        "/@react-types/",
        "/@internationalized/",
        "react-aria-components",
        "react-stately",
        "tailwindcss-react-aria-components"
      ]
    },
    {
      "groupName": "fumadocs",
      "matchPackageNames": ["/^fumadocs/"]
    },
    {
      "groupName": "testing",
      "matchPackageNames": [
        "/testing-library/",
        "/vitest/",
        "/playwright/",
        "/axe-playwright/"
      ]
    },
    {
      "groupName": "storybook",
      "matchPackageNames": ["/@storybook/", "/storybook/"]
    },
    {
      "groupName": "docs",
      "matchPackageNames": ["/^next$/", "/@next/", "eslint-config-next"]
    },
    {
      "groupName": "docs-demos",
      "matchPackageNames": ["react-hook-form", "/^zod/", "zod-form-data"]
    },
    {
      "groupName": "formatting",
      "matchPackageNames": [
        "/prettier/",
        "prettier-plugin-tailwindcss",
        "@trivago/prettier-plugin-sort-imports"
      ]
    },
    {
      "groupName": "git-cli",
      "matchPackageNames": ["simple-git", "zx", "concurrently"]
    },
    {
      "groupName": "tanstack",
      "matchPackageNames": ["/@tanstack/"]
    },
    {
      "groupName": "build-tools",
      "matchPackageNames": ["turbo", "tsdown"]
    },
    {
      "description": "Automerge non-major updates",
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "schedule": ["at any time"],
    "minimumReleaseAge": "0 days"
  },
  "osvVulnerabilityAlerts": true
}
