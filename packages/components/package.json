{
  "name": "@marigold/components",
  "version": "17.4.0",
  "description": "Components for the Marigold Design System",
  "license": "MIT",
  "keywords": [
    "marigiold",
    "components",
    "design",
    "design system",
    "react"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./legacy": {
      "import": {
        "types": "./dist/legacy.d.mts",
        "default": "./dist/legacy.mjs"
      },
      "require": {
        "types": "./dist/legacy.d.cts",
        "default": "./dist/legacy.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/marigold-ui/marigold",
    "directory": "packages/components"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.1",
    "@marigold/system": "workspace:*",
    "@marigold/types": "workspace:*",
    "@react-aria/button": "^3.15.0",
    "@react-aria/calendar": "^3.10.0",
    "@react-aria/collections": "3.1.0",
    "@react-aria/focus": "^3.22.0",
    "@react-aria/i18n": "^3.13.0",
    "@react-aria/interactions": "^3.28.0",
    "@react-aria/label": "^3.8.0",
    "@react-aria/landmark": "^3.1.0",
    "@react-aria/overlays": "^3.32.0",
    "@react-aria/selection": "^3.28.0",
    "@react-aria/ssr": "^3.10.0",
    "@react-aria/table": "^3.18.0",
    "@react-aria/utils": "^3.34.0",
    "@react-aria/visually-hidden": "^3.9.0",
    "@react-stately/collections": "^3.13.0",
    "@react-stately/data": "^3.16.0",
    "@react-stately/table": "^3.16.0",
    "@react-stately/tree": "^3.10.0",
    "@react-types/button": "^3.15.0",
    "@react-types/grid": "^3.3.0",
    "@react-types/shared": "^3.34.0",
    "@react-types/table": "^3.14.0",
    "motion": "12.34.3",
    "react-aria-components": "^1.17.0",
    "react-stately": "^3.45.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@marigold/icons": "workspace:*",
    "@marigold/tsconfig": "workspace:*",
    "@types/react": "19.2.14",
    "lucide-react": "^1.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsdown": "0.21.9"
  },
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "clean": "rm -rf node_modules && rm -rf dist"
  }
}
