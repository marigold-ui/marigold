{
  "name": "@marigold/cli",
  "version": "0.5.0-beta.0",
  "description": "Marigold Design System CLI — component docs, discovery, and project setup.",
  "license": "MIT",
  "keywords": [
    "marigold",
    "cli",
    "design-system",
    "docs"
  ],
  "type": "module",
  "bin": {
    "marigold": "./dist/bin/marigold.mjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/marigold-ui/marigold",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@babel/parser": "8.0.4",
    "@clack/prompts": "1.6.0",
    "ci-info": "4.4.0",
    "magic-string": "0.30.21",
    "picocolors": "1.1.1",
    "ts-morph": "^24.0.0",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "@axe-core/playwright": ">=4.10.0",
    "@marigold/components": ">=18.0.0-beta.0",
    "@marigold/theme-rui": ">=6.0.0-beta.0",
    "@vitejs/plugin-react": ">=4.0.0",
    "playwright": ">=1.40.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@axe-core/playwright": {
      "optional": true
    },
    "@marigold/components": {
      "optional": true
    },
    "@marigold/theme-rui": {
      "optional": true
    },
    "@vitejs/plugin-react": {
      "optional": true
    },
    "playwright": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@babel/types": "8.0.4",
    "@marigold/components": "workspace:*",
    "@marigold/system": "workspace:*",
    "@marigold/theme-rui": "workspace:*",
    "@marigold/tsconfig": "workspace:*",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "playwright": "1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsdown": "0.22.9",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  },
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf node_modules && rm -rf dist"
  }
}
