{
  "name": "@marigold/icons",
  "version": "2.0.0-beta.2",
  "description": "Marigold Icons (Lucide proxy + custom icons)",
  "license": "MIT",
  "keywords": [
    "marigold",
    "icons",
    "react",
    "svg",
    "lucide"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./*": {
      "require": "./dist/*.cjs",
      "import": "./dist/*.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/marigold-ui/marigold",
    "directory": "packages/icons"
  },
  "dependencies": {
    "@marigold/system": "workspace:*",
    "lucide-react": "^1.9.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@marigold/tsconfig": "workspace:*",
    "react": "19.2.6",
    "tsdown": "0.22.2"
  },
  "scripts": {
    "build": "tsdown src/index.ts",
    "watch": "tsdown src/index.ts --watch",
    "clean": "rm -rf node_modules && rm -rf dist"
  }
}
